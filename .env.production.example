# Copy this file to .env and replace every "change-me" value.
# Generate secrets with: openssl rand -hex 32

# Local app binding for host Caddy. Do not bind this to 0.0.0.0 in production.
NEW_API_BIND_ADDRESS=127.0.0.1
NEW_API_HOST_PORT=3000
NEW_API_IMAGE=new-api:production

# Runtime
PORT=3000
TZ=America/New_York
GIN_MODE=release
NODE_TYPE=master
NODE_NAME=new-api-prod-1
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
MEMORY_CACHE_ENABLED=true
SYNC_FREQUENCY=60
STREAMING_TIMEOUT=300
MAX_REQUEST_BODY_MB=128
STREAM_SCANNER_MAX_BUFFER_MB=128

# Security
SESSION_SECRET=change-me-generate-a-64-character-random-hex-string
CRYPTO_SECRET=change-me-generate-a-different-64-character-random-hex-string
SESSION_COOKIE_SECURE=true

# The app is only reachable from host Caddy on localhost.
TRUSTED_PROXIES=127.0.0.1/8,::1

# Comma-separated domains allowed for payment success/cancel redirects.
TRUSTED_REDIRECT_DOMAINS=example.com

# PostgreSQL
POSTGRES_USER=newapi
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=new-api
SQL_DSN=postgresql://newapi:change-me-postgres-password@postgres:5432/new-api

# Redis
REDIS_PASSWORD=change-me-redis-password
REDIS_CONN_STRING=redis://:change-me-redis-password@redis:6379/0
